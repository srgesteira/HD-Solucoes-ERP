# =====================================================================
# ERP HD Soluções Industriais — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com as credenciais
# do projeto Supabase "erp-hd-solucoes".
# =====================================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Project ID do Supabase (usado pelo script `npm run supabase:types`)
SUPABASE_PROJECT_ID=your-project-ref

# Base de dados — após actualizar o código, aplica as migrações (tabela epics, coluna tasks.epic_id):
#   npm run supabase:link   (se ainda não ligaste o CLI)
#   npx supabase db push
# ou corre o SQL em supabase/migrations/ no painel SQL do Supabase.

# ---------------------------------------------------------------------
# Anthropic Claude (opcional — análise de negócio no dashboard, NCM/BOM, etc.)
# Em produção (ex.: Vercel): adicione ANTHROPIC_API_KEY em Environment Variables e redeploy.
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=
# Modelo da API Messages (ex.: claude-sonnet-4-6). Modelos antigos são remapeados automaticamente.
ANTHROPIC_MODEL=claude-sonnet-4-6
