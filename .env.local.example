# =====================================================================
# ERP HD Soluções Industriais — variáveis de ambiente
# Copie este arquivo para .env.local e preencha com as credenciais
# do projeto Supabase "erp-hd-solucoes".
# =====================================================================

# Supabase (obrigatório)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Project ID do Supabase (usado pelo script `npm run supabase:types`)
SUPABASE_PROJECT_ID=your-project-ref
